{
  "_description": "Test sets for LLM tool invocation accuracy. Each entry has a user utterance and the expected tool call (or null for no tool). Used to measure precision and recall of tool calling.",
  "crm_tests": [
    {
      "id": "crm_01",
      "utterance": "My name is Ahmed and I have a budget of 2 Crore.",
      "expected_tool": "update_user_info",
      "expected_args_subset": {"field": "budget", "value": "2 Crore"},
      "description": "Should trigger CRM update with budget"
    },
    {
      "id": "crm_02",
      "utterance": "Change my phone number to 03001234567.",
      "expected_tool": "update_user_info",
      "expected_args_subset": {"field": "phone"},
      "description": "Should trigger CRM update with phone number"
    },
    {
      "id": "crm_03",
      "utterance": "Update my preferred area to DHA Phase 6.",
      "expected_tool": "update_user_info",
      "expected_args_subset": {"field": "preferred area"},
      "description": "Should trigger CRM update with area preference"
    },
    {
      "id": "crm_04",
      "utterance": "Set my marla preference to 10.",
      "expected_tool": "update_user_info",
      "expected_args_subset": {"field": "marla"},
      "description": "Should trigger CRM update with marla preference"
    },
    {
      "id": "crm_05",
      "utterance": "What do you know about me?",
      "expected_tool": "get_user_info",
      "expected_args_subset": {},
      "description": "Should trigger CRM read"
    },
    {
      "id": "crm_06",
      "utterance": "I want to see houses.",
      "expected_tool": null,
      "expected_args_subset": {},
      "description": "Should NOT trigger CRM — false positive check"
    },
    {
      "id": "crm_07",
      "utterance": "Hello, how are you?",
      "expected_tool": null,
      "expected_args_subset": {},
      "description": "Should NOT trigger CRM — casual greeting"
    }
  ],
