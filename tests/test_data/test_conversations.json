        {"role": "expected", "content_contains": ["welcome"], "stage_after": "greeting"},
        {"role": "user", "content": "What is the tax process for buying property in Pakistan?"},
        {"role": "expected", "content_contains": ["tax", "CVT", "stamp", "FBR"], "rag_required": true, "stage_after": "greeting"},
        {"role": "user", "content": "Calculate 2% of 4.2 crore for me."},
        {"role": "expected", "tool_expected": "calculate", "stage_after": "greeting"}
