        {"role": "expected", "content_contains": ["welcome"], "stage_after": "greeting"},
        {"role": "user", "content": "Tell me about DHA Phase 6 residential features."},
        {"role": "expected", "content_contains": ["DHA", "Phase 6"], "rag_required": true, "stage_after": "greeting"}
      ],
      "expected_outcome": {
        "task_completed": true,
        "rag_used": true
      }
    },
    {
      "id": "conv_12_mixed_rag_and_tool",
